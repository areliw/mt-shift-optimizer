# Core server
# HOST=0.0.0.0
# PORT=8000

# Security (required in production)
# API_KEY=replace-with-long-random-value
# ALLOWED_ORIGINS=https://your-app.example.com,https://admin.example.com
# SESSION_SECRET=replace-with-another-long-random-value

# Optional auth modes
# DISABLE_WORKSPACE_AUTH=0
# WORKSPACE_SESSION_TTL=43200
# ADMIN_SESSION_TTL=28800

# Optional admin panel
# ADMIN_ID=admin
# ADMIN_PASSWORD=replace-with-strong-password

# Environment hint (auto-detected if omitted)
# APP_ENV=development
# FORCE_PRODUCTION=0
